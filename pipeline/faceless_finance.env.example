# ---- copy these into GitHub repo Secrets (Settings -> Secrets and variables -> Actions) ----

# Script (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Voice (ElevenLabs clone "JB Blues")
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=Ddap889CVJzcRLn7e4nG
ELEVENLABS_MODEL=eleven_multilingual_v2

# Render engine selection (modular - swap per shot type)
RENDER_TO_CAMERA=hedra          # hedra | higgsfield   (lip-sync close-ups)
RENDER_MOTION=hedra             # hedra | higgsfield   (walk / b-roll motion)

# Hedra (default engine - uses your existing Hedra credits)
HEDRA_API_KEY=
# model ids are pre-filled defaults; override only if Hedra changes them
HEDRA_AVATAR_MODEL_ID=26f0fc66-152b-40ab-abed-76c43df99bc8
HEDRA_OMNIA_MODEL_ID=ab372b84-432f-44f5-bacc-c2542465f712

# Higgsfield (premium cinematic - OPTIONAL, leave blank until validated)
HIGGSFIELD_TOKEN=
HIGGSFIELD_API_BASE=            # set the validated REST base, then RENDER_MOTION=higgsfield
HIGGSFIELD_SOUL_ID=64da88e0-fe5f-4af6-a2da-3b8de23fad64

# Presenter stills (your Soul on the Higgsfield CDN, or any hosted PNG)
PRESENTER_IMAGE_URL=            # head-and-shoulders still (to-camera lip-sync)
FULLBODY_IMAGE_URL=             # full-body still (walk/motion); defaults to presenter if blank

# Publish (off by default). Set repo VARIABLE POST_TO_TIKTOK=true to enable.
POST_TO_TIKTOK=false
# Option A - the repo Worker (multi-platform OAuth):
WORKER_PUBLISH_URL=
WORKER_SECRET=
# Option B - Blotato (interim, TikTok):
BLOTATO_API_KEY=
BLOTATO_TIKTOK_ACCOUNT_ID=
