# ── Faceless Finance pipeline configuration ────────────────────────────────
# Copy to `.env` and fill in. Never commit the real .env.

# General
LOG_LEVEL=info            # debug | info | warn | error
VIDEO_ASPECT=9:16         # vertical for TikTok / Shorts / Reels
CHANNEL_TONE=rebecca      # mat | rebecca | neutral

# Script generation (Anthropic / Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Voice (ElevenLabs) — your professional voice clone
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=          # the "JB Blues Script" PVC voice id
ELEVENLABS_MODEL=eleven_multilingual_v2

# Talking video (HeyGen) — the walking, talk-to-camera "Elliot" twin
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=             # the avatar_id (studio avatar) OR talking_photo_id (photo twin)
# A twin built from reference photos (Avatar IV) is a `talking_photo`; a HeyGen
# studio avatar is an `avatar`. Set this to match how you created Elliot.
HEYGEN_CHARACTER_TYPE=avatar  # avatar | talking_photo
HEYGEN_AVATAR_STYLE=normal    # only used when HEYGEN_CHARACTER_TYPE=avatar
# HEYGEN_POLL_INTERVAL_MS=10000
# HEYGEN_POLL_TIMEOUT_MS=1200000

# Auto-publishing (self-hosted Postiz). Set POSTIZ_ENABLED=false to render only.
POSTIZ_ENABLED=true
POSTIZ_URL=https://postiz.yourdomain.com
POSTIZ_API_KEY=
# Connected channel integration ids, comma-separated. Append :platform — Postiz
# requires a per-provider settings.__type, and it also selects the right
# caption/title (e.g. youtube gets the title field).
POSTIZ_INTEGRATION_IDS=abc123:tiktok,def456:youtube,ghi789:instagram

# Compliance — appended verbatim to every caption. Override only if your
# disclaimer wording changes.
# FCA_DISCLAIMER=This is for educational purposes only and is not financial advice...
