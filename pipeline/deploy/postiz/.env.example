# Postiz self-host secrets. Copy to `.env` in this directory. Never commit it.

# Public URL Postiz is served on (must be https in production for OAuth to work).
POSTIZ_DOMAIN=https://postiz.yourdomain.com

# Long random strings. Generate with: openssl rand -hex 32
JWT_SECRET=
POSTGRES_PASSWORD=

# Per-platform OAuth app credentials (uncomment the matching lines in
# docker-compose.yml too). See README.md for where to create each app.
# TIKTOK_CLIENT_ID=
# TIKTOK_CLIENT_SECRET=
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# INSTAGRAM_APP_ID=
# INSTAGRAM_APP_SECRET=
