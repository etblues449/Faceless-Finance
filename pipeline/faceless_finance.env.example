# Faceless Finance — copy this file to ".env" (same folder as the script) and fill in.
# Keep .env private. Never commit it to git.

# --- Required ---
ANTHROPIC_API_KEY=sk-ant-...            # console.anthropic.com (pay-as-you-go, separate from Claude.ai)
ELEVENLABS_API_KEY=sk_...               # your NEW ElevenLabs key (rotate the old exposed one)
ELEVENLABS_VOICE_ID=Ddap889CVJzcRLn7e4nG   # your cloned "JB Blues" voice
HEDRA_API_KEY=...                       # hedra.com/api-profile (accept ToS first). Uses your existing credits.

# --- Presenter face (already rendered on your Higgsfield account; reused every video) ---
PRESENTER_IMAGE_URL=https://d8j0ntlcm91z4.cloudfront.net/user_3DTLmgHXqDZdcq1wpnNDD4pHteF/hf_20260526_025508_42fb418a-ed9d-4080-8591-fd6c8deecfb5.png

# --- Video options ---
ASPECT_RATIO=9:16
RESOLUTION=720p
ANTHROPIC_MODEL=claude-sonnet-4-6
# HEDRA_MODEL_ID=26f0fc66-152b-40ab-abed-76c43df99bc8   # Hedra Avatar (default; only change to switch models)

# --- Posting (leave POST_TO_TIKTOK=false until you've watched a few; then flip to true) ---
POST_TO_TIKTOK=false
BLOTATO_API_KEY=
BLOTATO_TIKTOK_ACCOUNT_ID=
